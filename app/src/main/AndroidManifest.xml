<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Runtime permission on Android 13+ (handled in-app with a rationale). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Lets a DOWN alert launch full-screen over the lock screen, like an
         incoming call/alarm. Granted automatically pre-14; on 14+ the user
         must flip it on in Settings (requested in-app, see NotificationPermission.kt). -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <!-- Lets the app ask to be exempted from battery-optimization killing —
         several OEMs (Samsung, Xiaomi, Oppo) suspend background FCM delivery
         otherwise, which is why alerts silently never arrive on some devices. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Backs the downtime channel's setBypassDnd(true) — without the user
         separately granting Do Not Disturb access (Settings, no runtime
         dialog), Android ignores that flag and DND silences the alert. -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <application
        android:name=".PantawinApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Pantawin">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Pantawin">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Deep link: pantawin://monitor/{id} (notification taps). -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="pantawin" android:host="monitor" />
            </intent-filter>
        </activity>

        <!-- FCM receiver. Dormant until Firebase is configured (see PantawinApp). -->
        <service
            android:name=".push.PantawinMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Default notification icon/color for FCM-rendered notifications. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_stat_alert" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="downtime_alerts_v2" />

    </application>

</manifest>
