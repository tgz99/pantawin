<?xml version="1.0" encoding="utf-8"?><!--
    Resources only reached via Resources.getIdentifier(), which the release
    resource shrinker can't trace. default_web_client_id gates the
    Continue-with-Google button (LoginScreen) — shrinking it away silently
    hides Google sign-in in release builds.
-->
<resources xmlns:tools="http://schemas.android.com/tools"
    tools:keep="@string/default_web_client_id" />
