# Copy to deploy/.env on the VPS (chmod 600), fill in real values, and never
# commit the filled-in version — .gitignore already excludes deploy/.env.

# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=
JWT_SECRET=

# Bootstrap account — created on first boot if no users exist yet.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# M0 seed monitor (defaults shown; override if monitoring something else).
SEED_MONITOR_NAME=gratisaja.com
SEED_MONITOR_URL=https://gratisaja.com

# Pin to a specific tag once images are built via CI; defaults to a local
# build from ../server for now.
API_IMAGE=pantawin-api:latest
